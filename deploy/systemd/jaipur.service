[Unit]
Description=Tabletopia Jaipur Server
After=network.target

[Service]
Type=simple
WorkingDirectory=/opt/tabletopia/jaipur/packages/server
Environment=NODE_ENV=production
Environment=PORT=3007
Environment=ALLOWED_ORIGIN=https://game.yuxinlai.com,http://game.yuxinlai.com
ExecStart=/usr/bin/npm run start
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
